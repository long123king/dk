+    : m_pointer_size(0)
 { 
     ExtSetDllMain::ExtSetDllMain(CmdListMain);
 } 
 
+ULONG CCmdExt::pointer_size()
+{
+    if (m_pointer_size == 0)
+    {
+        // Query the debugger for the target's pointer size.
+        // 4 = 32-bit target, 8 = 64-bit target.
+        // IDebugControl::GetPointerSize is the standard dbgeng API.
+        if (FAILED(m_Control->GetPointerSize(&m_pointer_size)))
+            m_pointer_size = sizeof(size_t);  // fallback: assume host pointer size
+    }
+    return m_pointer_size;
+}
+
 bool CCmdExt::is_reg(std::string & str)
 {
-    static std::vector<std::string> regs{ {
+    static std::vector<std::string> regs_x64{ {
             "rax", "rbx", "rcx", "rdx", "rsi", "rdi", "rsp", "rbp", "rip",
             "r8", "r9", "r10", "r11", "r12", "r13", "r14", "r15", "r16"
         } };
+    static std::vector<std::string> regs_x86{ {
+            "eax", "ebx", "ecx", "edx", "esi", "edi", "esp", "ebp", "eip"
+        } };
 
+    auto& regs = (pointer_size() == 8) ? regs_x64 : regs_x86;
     return std::find(regs.begin(), regs.end(), str.c_str()) != regs.end();
 }
 
